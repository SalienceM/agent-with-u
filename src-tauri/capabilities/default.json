{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capability — allows dialog, shell sidecar",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "core:webview:allow-create-webview-window",
    "shell:allow-execute",
    "shell:allow-spawn",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
